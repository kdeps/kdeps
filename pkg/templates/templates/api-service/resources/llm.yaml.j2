actionId: llm
name: LLM Chat

validations:
  methods: [POST]
  routes: [/api/v1/chat]
  check:
    - get('q') != ''
  error:
    code: 400
    message: "'q' is required"

chat:
  model: llama3.2:1b  # llamafile alias - auto-downloaded to ~/.kdeps/models (~1.1 GB, first run only)
  # Default backend is "file": the model runs as a local llamafile, no server install needed.
  # Quantization variants: llama3.2:1b-q6, llama3.2:1b-q8. List all: kdeps llamafile list
  # To use ollama instead: set KDEPS_DEFAULT_BACKEND=ollama and installOllama: true in workflow.yaml
  role: user
  prompt: "{% raw %}{{ get('q') }}{% endraw %}"
  timeout: 60s
