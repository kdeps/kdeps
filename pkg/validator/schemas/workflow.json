{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": [
    "apiVersion",
    "kind",
    "metadata",
    "settings"
  ],
  "properties": {
    "apiVersion": {
      "type": "string",
      "enum": [
        "kdeps.io/v1"
      ]
    },
    "kind": {
      "type": "string",
      "enum": [
        "Workflow"
      ]
    },
    "metadata": {
      "type": "object",
      "required": [
        "name",
        "targetActionId"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string"
        },
        "version": {
          "type": "string"
        },
        "targetActionId": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "settings": {
      "type": "object",
      "properties": {
        "apiServer": {
          "type": "object",
          "properties": {
            "hostIp": {
              "type": "string"
            },
            "portNum": {
              "type": "integer",
              "minimum": 1,
              "maximum": 65535
            },
            "routes": {
              "type": "array",
              "items": {
                "type": "object",
                "required": [
                  "path"
                ],
                "properties": {
                  "path": {
                    "type": "string",
                    "pattern": "^/"
                  },
                  "methods": {
                    "type": "array",
                    "items": {
                      "type": "string",
                      "enum": [
                        "GET",
                        "POST",
                        "PUT",
                        "DELETE",
                        "PATCH"
                      ]
                    }
                  }
                }
              }
            }
          }
        },
        "agentSettings": {
          "type": "object",
          "properties": {
            "timezone": {
              "type": "string"
            },
            "pythonVersion": {
              "type": "string"
            },
            "pythonPackages": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "requirementsFile": {
              "type": "string"
            }
          }
        },
        "input": {
          "type": "object",
          "required": [
            "sources"
          ],
          "properties": {
            "sources": {
              "type": "array",
              "minItems": 1,
              "uniqueItems": true,
              "items": {
                "type": "string",
                "enum": [
                  "api",
                  "audio",
                  "video",
                  "telephony",
                  "bot",
                  "file",
                  "component",
                  "llm"
                ]
              }
            },
            "audio": {
              "type": "object",
              "properties": {
                "device": {
                  "type": "string"
                }
              }
            },
            "video": {
              "type": "object",
              "properties": {
                "device": {
                  "type": "string"
                }
              }
            },
            "telephony": {
              "type": "object",
              "required": [
                "type"
              ],
              "properties": {
                "type": {
                  "type": "string",
                  "enum": [
                    "local",
                    "online"
                  ]
                },
                "device": {
                  "type": "string"
                },
                "provider": {
                  "type": "string"
                }
              }
            },
            "file": {
              "type": "object",
              "properties": {
                "path": {
                  "type": "string"
                }
              }
            },
            "component": {
              "type": "object",
              "properties": {
                "description": {
                  "type": "string"
                }
              }
            },
            "llm": {
              "type": "object",
              "properties": {
                "executionType": {
                  "type": "string",
                  "enum": [
                    "stdin",
                    "apiServer"
                  ]
                },
                "prompt": {
                  "type": "string"
                },
                "sessionId": {
                  "type": "string"
                }
              }
            },
            "transcriber": {
              "type": "object",
              "required": [
                "mode"
              ],
              "properties": {
                "mode": {
                  "type": "string",
                  "enum": [
                    "online",
                    "offline"
                  ]
                },
                "output": {
                  "type": "string",
                  "enum": [
                    "text",
                    "media"
                  ]
                },
                "language": {
                  "type": "string"
                },
                "online": {
                  "type": "object",
                  "required": [
                    "provider"
                  ],
                  "properties": {
                    "provider": {
                      "type": "string",
                      "enum": [
                        "openai-whisper",
                        "google-stt",
                        "aws-transcribe",
                        "deepgram",
                        "assemblyai"
                      ]
                    },
                    "apiKey": {
                      "type": "string"
                    },
                    "region": {
                      "type": "string"
                    },
                    "projectId": {
                      "type": "string"
                    }
                  }
                },
                "offline": {
                  "type": "object",
                  "required": [
                    "engine"
                  ],
                  "properties": {
                    "engine": {
                      "type": "string",
                      "enum": [
                        "whisper",
                        "faster-whisper",
                        "vosk",
                        "whisper-cpp"
                      ]
                    },
                    "model": {
                      "type": "string"
                    }
                  }
                }
              }
            },
            "activation": {
              "type": "object",
              "required": [
                "phrase",
                "mode"
              ],
              "properties": {
                "phrase": {
                  "type": "string"
                },
                "mode": {
                  "type": "string",
                  "enum": [
                    "online",
                    "offline"
                  ]
                },
                "sensitivity": {
                  "type": "number",
                  "minimum": 0,
                  "maximum": 1
                },
                "chunkSeconds": {
                  "type": "integer",
                  "minimum": 1
                },
                "online": {
                  "type": "object",
                  "required": [
                    "provider"
                  ],
                  "properties": {
                    "provider": {
                      "type": "string",
                      "enum": [
                        "openai-whisper",
                        "google-stt",
                        "aws-transcribe",
                        "deepgram",
                        "assemblyai"
                      ]
                    },
                    "apiKey": {
                      "type": "string"
                    },
                    "region": {
                      "type": "string"
                    },
                    "projectId": {
                      "type": "string"
                    }
                  }
                },
                "offline": {
                  "type": "object",
                  "required": [
                    "engine"
                  ],
                  "properties": {
                    "engine": {
                      "type": "string",
                      "enum": [
                        "whisper",
                        "faster-whisper",
                        "vosk",
                        "whisper-cpp"
                      ]
                    },
                    "model": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          },
          "allOf": [
            {
              "if": {
                "properties": {
                  "sources": {
                    "contains": {
                      "const": "telephony"
                    }
                  }
                }
              },
              "then": {
                "required": [
                  "telephony"
                ]
              }
            }
          ]
        }
      }
    },
    "resources": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/resource"
      }
    }
  },
  "$defs": {
    "resource": {
      "type": "object",
      "required": [
        "actionId",
        "name"
      ],
      "properties": {
        "apiVersion": {
          "type": "string",
          "enum": [
            "kdeps.io/v1"
          ]
        },
        "kind": {
          "type": "string",
          "enum": [
            "Resource"
          ]
        },
        "actionId": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string"
        },
        "requires": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "items": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}
