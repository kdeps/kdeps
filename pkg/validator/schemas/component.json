{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["apiVersion", "kind", "metadata"],
  "properties": {
    "apiVersion": {
      "type": "string",
      "enum": ["kdeps.io/v1"]
    },
    "kind": {
      "type": "string",
      "enum": ["Component"]
    },
    "metadata": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string"
        },
        "version": {
          "type": "string"
        },
        "targetActionId": {
          "type": "string",
          "minLength": 1,
          "description": "ActionID of the resource that acts as the component entry point"
        }
      },
      "additionalProperties": false
    },
    "interface": {
      "type": "object",
      "properties": {
        "inputs": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "type"],
            "properties": {
              "name": {
                "type": "string",
                "minLength": 1
              },
              "type": {
                "type": "string",
                "enum": ["string", "integer", "number", "boolean"]
              },
              "required": {
                "type": "boolean"
              },
              "description": {
                "type": "string"
              },
              "default": {}
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "pythonPackages": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "description": "Python packages required by this component. Merged into the workflow's agentSettings.pythonPackages at load time."
    },
    "resources": {
      "type": "array"
    }
  },
  "additionalProperties": false
}
