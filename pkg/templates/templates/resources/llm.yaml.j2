apiVersion: v2
kind: Resource
metadata:
  actionId: llm
  name: LLM Processing
  description: Large Language Model interaction
run:
  chat:
    model: llama3.2:1b  # llamafile alias - auto-downloaded to ~/.kdeps/models (~1.1 GB, first run only)
    # Default backend is "file": the model runs as a local llamafile, no server install needed.
    # Quantization variants: llama3.2:1b-q6, llama3.2:1b-q8. List all: kdeps llamafile list
    role: user
    prompt: "{% raw %}{{ get('input', 'Hello, how can you help me?') }}{% endraw %}"
    jsonResponse: true
    jsonResponseKeys:
      - answer
      - reasoning
    timeout: "60s"
  validations:
    required:
      - input
    rules:
      - field: input
        type: string
        minLength: 1
        message: "Input is required"
