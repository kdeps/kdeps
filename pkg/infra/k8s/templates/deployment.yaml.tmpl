apiVersion: apps/v1
kind: Deployment
metadata:
  name: {{ .Name }}
  labels:
    app: {{ .Name }}
    version: {{ .Version }}
    kdeps-component: "true"
spec:
  replicas: {{ .Replicas }}
  selector:
    matchLabels:
      app: {{ .Name }}
  template:
    metadata:
      labels:
        app: {{ .Name }}
    spec:
      automountServiceAccountToken: false  # kdeps workloads never call the Kubernetes API
      securityContext:
        runAsNonRoot: true
        seccompProfile:
          type: RuntimeDefault
      containers:
      - name: {{ .Name }}
        image: {{ .Image }}
        securityContext:
          allowPrivilegeEscalation: false
          readOnlyRootFilesystem: false
          capabilities:
            drop: ["ALL"]
        ports:
        {{- if .APIPort }}
        - containerPort: {{ .APIPort }}
          name: api
        {{- end }}
        {{- if .WebServerPort }}
        - containerPort: {{ .WebServerPort }}
          name: web
        {{- end }}
        {{- if .BackendPort }}
        - containerPort: {{ .BackendPort }}
          name: backend
        {{- end }}
        env:
        {{- if .HasAPIServer }}
        - name: KDEPS_API_AUTH_TOKEN
          valueFrom:
            secretKeyRef:
              name: {{ .Name }}-auth
              key: api-token
        - name: KDEPS_MANAGEMENT_TOKEN
          valueFrom:
            secretKeyRef:
              name: {{ .Name }}-auth
              key: management-token
              optional: true
        {{- end }}
        {{- range $key, $value := .Env }}
        - name: {{ $key }}
          value: "{{ $value }}"
        {{- end }}
        {{- range $key := .SecretEnv }}
        - name: {{ $key }}
          valueFrom:
            secretKeyRef:
              name: {{ $.Name }}-env
              key: {{ $key }}
        {{- end }}
        {{- if .Resources }}
        resources:
          limits:
            cpu: "{{ .Resources.CPULimit }}"
            memory: "{{ .Resources.MemoryLimit }}"
          requests:
            cpu: "{{ .Resources.CPURequest }}"
            memory: "{{ .Resources.MemoryRequest }}"
        {{- end }}
        readinessProbe:
          httpGet:
            path: /health
            port: {{ .APIPort }}
          initialDelaySeconds: 10
          periodSeconds: 10
        livenessProbe:
          httpGet:
            path: /health
            port: {{ .APIPort }}
          initialDelaySeconds: 30
          periodSeconds: 30
