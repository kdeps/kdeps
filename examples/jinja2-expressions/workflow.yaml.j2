apiVersion: kdeps.io/v1
kind: Workflow

metadata:
  name: jinja2-expressions-demo
  description: "{{ env.KDEPS_APP_DESC | default('Demonstrates Jinja2 preprocessing in kdeps') }}"
  version: "1.0.0"
  targetActionId: response

{# Jinja2 comment: set port from environment or use default #}

settings:
  apiServerMode: true
  apiServer:
    hostIp: "0.0.0.0"
{% if env.PORT %}
    portNum: {{ env.PORT | int }}
{% else %}
    portNum: 16397
{% endif %}
    routes:
      - path: /api/demo
        methods: [GET, POST]
    cors:
      allowOrigins:
        - "*"

  agentSettings:
    timezone: Etc/UTC
